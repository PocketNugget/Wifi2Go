{
  "tasks": {
    "start": "deno run --allow-net --allow-env --allow-read --allow-write --allow-ffi --unstable-ffi main.ts",
    "db:setup": "deno run --allow-env --allow-read --allow-write --allow-ffi --unstable-ffi db/setup.ts",
    "dev": "deno run --watch --allow-net --allow-env --allow-read --allow-write --allow-ffi --unstable-ffi main.ts"
  },
  "compilerOptions": {
    "strict": true
  }
}
